# This file includes environment variables that will be committed to git by default.

# Built-in environment variables
TEAMSFX_ENV=dev
APP_NAME_SUFFIX=dev

# Updating AZURE_SUBSCRIPTION_ID or AZURE_RESOURCE_GROUP_NAME after provision may also require an update to RESOURCE_SUFFIX, because some services require a globally unique name across subscriptions/resource groups.
AZURE_SUBSCRIPTION_ID=f07d0553-10b5-4519-8d1b-e93aaf388142
AZURE_RESOURCE_GROUP_NAME=EdgarO_RG_MCPP_WU2

# Graph API app registration (separate from bot identity - used for chat/message access)
GRAPH_CLIENT_ID=7ed650f2-28d9-4c03-b660-2fe0bbb98434

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://ai-foundry-main-001.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1

# Cognitive Services (optional - for speech-to-text)
COGNITIVE_SERVICES_ENDPOINT=https://eastus.api.cognitive.microsoft.com/

# Generated during provision - will be filled automatically
RESOURCE_SUFFIX=f4cce4
# For local testing without conflicts, use a unique app ID. Change this before running `npm run dev`
# Production ID: b4893c70-dd34-491a-be17-839d77bd55cc
# Local dev ID (change each local test to avoid conflicts): dde615d7-ecb3-4589-9aa0-51ad1db0e9d3
TEAMS_APP_ID=dde615d7-ecb3-4589-9aa0-51ad1db0e9d3
TEAMS_APP_TENANT_ID=588cadf4-9902-4465-86c0-8bcf04f4f102
BOT_AZURE_APP_SERVICE_RESOURCE_ID=/subscriptions/f07d0553-10b5-4519-8d1b-e93aaf388142/resourceGroups/EdgarO_RG_MCPP_WU2/providers/Microsoft.Web/sites/botf4cce4
BOT_DOMAIN=botf4cce4.azurewebsites.net
BOT_ENDPOINT=https://botf4cce4.azurewebsites.net
BOT_ID=7ed650f2-28d9-4c03-b660-2fe0bbb98434
BOT_TENANT_ID=588cadf4-9902-4465-86c0-8bcf04f4f102
TEAMS_APP_PUBLISHED_APP_ID=81a8850c-c326-49ed-9f96-887326b8b6d4

# AI email sender - all AI-generated emails sent from this address
EMAIL_SENDER_USER_ID=ai.solutions@armely.com

# Recorder integration (Mela -> Missa Recorder)
RECORDER_ENABLED=true
RECORDER_BASE_URL=https://missa-recorder.azurewebsites.net
# RECORDER_SHARED_SECRET is stored in .env.dev.user as SECRET_RECORDER_SHARED_SECRET